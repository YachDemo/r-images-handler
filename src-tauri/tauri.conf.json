{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "R-Image Studio",
  "version": "0.1.5",
  "identifier": "com.yanch.r-images-handler",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "R-Image Studio",
        "width": 1280,
        "height": 860,
        "center": true
      }
    ],
    "security": {
      "csp": null,
      "assetProtocol": {
        "enable": true,
        "scope": ["**"]
      }
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDgwQTU2MTFGMDM5RjU1RkUKUldUK1ZaOERIMkdsZ0cyN2tzNTdKQ05vb2JZakdjWXhOK0djdy9FSnFFQzVaMHRRY1BLS2xKTTAK",
      "endpoints": [
        "https://github.com/YachDemo/r-images-handler/releases/latest/download/latest.json"
      ]
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
